# =========================
# Basic
# =========================
API_TOKEN=
ENCRYPTION_KEY=
ADMIN_TOKEN=

# =========================
# Provider Tokens
# 留空表示不用该渠道
# 多个值如果项目支持，一般按逗号分隔
# =========================
HUGGINGFACE_TOKENS=
GITEE_TOKENS=
MODELSCOPE_TOKENS=
A4F_TOKENS=
GEMINI_TOKENS=
GROK_TOKENS=
OPENAI_TOKENS=${LLM_MetAPI}
MODELSLAB_TOKENS=

# =========================
# Custom API Base
# 不需要自定义时可留空
# =========================
GEMINI_API_BASE=
GROK_API_BASE=
OPENAI_API_BASE=https://api.lucc.dev/v1

# =========================
# S3 / Object Storage
# 不用对象存储时可留空
# =========================
S3_ENDPOINT=https://${CF_ACCOUNT}.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=${CF_R2_AK}
S3_SECRET_ACCESS_KEY=${CF_R2_SK}
S3_BUCKET_NAME=seed-flow
S3_CDN_URL=https://sf.lucc.dev
