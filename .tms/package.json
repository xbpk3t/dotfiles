{
  "name": "dotfiles-tms",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "verify": "pnpm -r --filter './packages/*' run verify",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:run": "FLOMO_CLEANER_ALLOW_DESTRUCTIVE=1 playwright test -g destructive",
    "setup:flomo-profile": "tsx e2e/setup-flomo-profile.ts"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "8.46.1",
    "@playwright/test": "1.53.1",
    "tsx": "4.19.4",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-plugin-monkey": "8.0.2",
    "vitest": "4.1.5"
  }
}
